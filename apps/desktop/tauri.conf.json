{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HangCore Agent",
  "identifier": "com.hangshun.hangcoreagent",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --filter=./ui dev",
    "beforeBuildCommand": "bun scripts/prune-build.mjs --pre && bun run --filter=./ui build"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["../../ui/dist"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hangcore"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/Alvinzero/HangCore-Agent/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5QUI4RkFDRTRBRDI1MEQKUldRTkphM2tySStyaVQwODJDZU1vK0p6TWpxdTdWbG8vRDZCbTZmdkRYTTFGU01HT3NHKzQzVXoK"
    }
  }
}
